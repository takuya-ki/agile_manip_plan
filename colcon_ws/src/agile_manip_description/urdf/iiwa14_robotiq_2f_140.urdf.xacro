<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="iiwa14_robotiq_2f_140">

  <!-- ============================================================ -->
  <!-- Arguments                                                     -->
  <!-- ============================================================ -->
  <xacro:arg name="prefix" default=""/>
  <!-- ``articulated_gripper:=true`` (default) renders the full Robotiq -->
  <!-- 2F-140 model with ``finger_joint`` + 5 mimic joints - used by    -->
  <!-- robot_state_publisher / RViz so the gripper can visually open    -->
  <!-- and close. ``articulated_gripper:=false`` collapses the gripper  -->
  <!-- to a single fixed mesh at the flange - used by cuMotion, which   -->
  <!-- only plans arm motion and fails on locked mimic joints.          -->
  <xacro:arg name="articulated_gripper" default="true"/>

  <xacro:property name="prefix" value="$(arg prefix)"/>

  <!-- Colors -->
  <material name="iiwa_orange">
    <color rgba="1.0 0.42 0.04 1.0"/>
  </material>
  <material name="iiwa_grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="gripper_dark">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <!-- ============================================================ -->
  <!-- World link                                                    -->
  <!-- ============================================================ -->
  <link name="world"/>
  <joint name="${prefix}world_to_base" type="fixed">
    <parent link="world"/>
    <child link="${prefix}iiwa_base_link"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LBR iiwa 14 R820                                              -->
  <!-- ============================================================ -->

  <!-- Base link -->
  <link name="${prefix}iiwa_base_link">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_0.stl"/>
      </geometry>
      <material name="iiwa_grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_0.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.06" iyz="0.0" izz="0.03"/>
    </inertial>
  </link>

  <!-- Link 1 -->
  <joint name="${prefix}iiwa_joint_1" type="revolute">
    <parent link="${prefix}iiwa_base_link"/>
    <child link="${prefix}iiwa_link_1"/>
    <origin xyz="0 0 0.1575" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-170 * pi / 180}" upper="${170 * pi / 180}" effort="320" velocity="${85 * pi / 180}"/>
  </joint>
  <link name="${prefix}iiwa_link_1">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_1.stl"/>
      </geometry>
      <material name="iiwa_orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 -0.03 0.12" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.09" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <!-- Link 2 -->
  <joint name="${prefix}iiwa_joint_2" type="revolute">
    <parent link="${prefix}iiwa_link_1"/>
    <child link="${prefix}iiwa_link_2"/>
    <origin xyz="0 0 0.2025" rpy="${pi / 2} 0 ${pi}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-120 * pi / 180}" upper="${120 * pi / 180}" effort="320" velocity="${85 * pi / 180}"/>
  </joint>
  <link name="${prefix}iiwa_link_2">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_2.stl"/>
      </geometry>
      <material name="iiwa_grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_2.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0.0003 0.059 0.042" rpy="0 0 0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.018" iyz="0.0" izz="0.044"/>
    </inertial>
  </link>

  <!-- Link 3 -->
  <joint name="${prefix}iiwa_joint_3" type="revolute">
    <parent link="${prefix}iiwa_link_2"/>
    <child link="${prefix}iiwa_link_3"/>
    <origin xyz="0 0.2045 0" rpy="${pi / 2} 0 ${pi}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-170 * pi / 180}" upper="${170 * pi / 180}" effort="176" velocity="${100 * pi / 180}"/>
  </joint>
  <link name="${prefix}iiwa_link_3">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_3.stl"/>
      </geometry>
      <material name="iiwa_orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_3.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0.03 0.13" rpy="0 0 0"/>
      <inertia ixx="0.08" ixy="0.0" ixz="0.0" iyy="0.075" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Link 4 -->
  <joint name="${prefix}iiwa_joint_4" type="revolute">
    <parent link="${prefix}iiwa_link_3"/>
    <child link="${prefix}iiwa_link_4"/>
    <origin xyz="0 0 0.2155" rpy="${pi / 2} 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-120 * pi / 180}" upper="${120 * pi / 180}" effort="176" velocity="${75 * pi / 180}"/>
  </joint>
  <link name="${prefix}iiwa_link_4">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_4.stl"/>
      </geometry>
      <material name="iiwa_grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_4.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.7"/>
      <origin xyz="0 0.067 0.034" rpy="0 0 0"/>
      <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.029"/>
    </inertial>
  </link>

  <!-- Link 5 -->
  <joint name="${prefix}iiwa_joint_5" type="revolute">
    <parent link="${prefix}iiwa_link_4"/>
    <child link="${prefix}iiwa_link_5"/>
    <origin xyz="0 0.1845 0" rpy="${-pi / 2} ${pi} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-170 * pi / 180}" upper="${170 * pi / 180}" effort="110" velocity="${130 * pi / 180}"/>
  </joint>
  <link name="${prefix}iiwa_link_5">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_5.stl"/>
      </geometry>
      <material name="iiwa_orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_5.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.7"/>
      <origin xyz="0.0001 0.021 0.076" rpy="0 0 0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.018" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <!-- Link 6 -->
  <joint name="${prefix}iiwa_joint_6" type="revolute">
    <parent link="${prefix}iiwa_link_5"/>
    <child link="${prefix}iiwa_link_6"/>
    <origin xyz="0 0 0.2155" rpy="${pi / 2} 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-120 * pi / 180}" upper="${120 * pi / 180}" effort="40" velocity="${135 * pi / 180}"/>
  </joint>
  <link name="${prefix}iiwa_link_6">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_6.stl"/>
      </geometry>
      <material name="iiwa_grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_6.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.8"/>
      <origin xyz="0 0.0006 0.0004" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.0036" iyz="0.0" izz="0.0047"/>
    </inertial>
  </link>

  <!-- Link 7 (flange) -->
  <joint name="${prefix}iiwa_joint_7" type="revolute">
    <parent link="${prefix}iiwa_link_6"/>
    <child link="${prefix}iiwa_link_7"/>
    <origin xyz="0 0.081 0" rpy="${-pi / 2} ${pi} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-175 * pi / 180}" upper="${175 * pi / 180}" effort="40" velocity="${135 * pi / 180}"/>
  </joint>
  <link name="${prefix}iiwa_link_7">
    <visual>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/visual/link_7.stl"/>
      </geometry>
      <material name="iiwa_grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://agile_manip_description/meshes/iiwa14/collision/link_7.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- Coupling: iiwa flange -> Robotiq 2F-140                       -->
  <!-- ============================================================ -->
  <!-- ``grasp_frame`` is the common tool frame that cuMotion targets -->
  <!-- and that GraspGen positions grasps against. Its +X axis is the -->
  <!-- finger-opening direction (matching the ``robotiq_140_collision -->
  <!-- .stl`` mesh convention used by GraspGen for grasp inference).  -->
  <xacro:if value="$(arg articulated_gripper)">
    <!-- Full Robotiq 2F-140 model (6 meshes, ``finger_joint`` +       -->
    <!-- 5 mimic joints). Used by robot_state_publisher so RViz can    -->
    <!-- animate open/close via /joint_states. cuMotion never sees     -->
    <!-- this URDF (it receives the articulated_gripper:=false variant).-->
    <xacro:include filename="$(find robotiq_2f_gripper_description)/urdf/robotiq_2f_140_macro.xacro"/>
    <xacro:robotiq_arg2f_140 prefix=""/>

    <joint name="${prefix}iiwa_to_grasp_frame" type="fixed">
      <parent link="${prefix}iiwa_link_7"/>
      <child link="${prefix}grasp_frame"/>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}grasp_frame"/>

    <!-- The articulated macro opens its fingers along the base link's  -->
    <!-- local +Y axis, but the GraspGen reference mesh opens along +X. -->
    <!-- Mount the articulated base under grasp_frame with a -90 deg Z  -->
    <!-- rotation so the two conventions line up visually in RViz.     -->
    <joint name="${prefix}grasp_frame_to_robotiq" type="fixed">
      <parent link="${prefix}grasp_frame"/>
      <child link="${prefix}robotiq_arg2f_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 ${-pi/2}"/>
    </joint>
  </xacro:if>

  <xacro:unless value="$(arg articulated_gripper)">
    <!-- Simple fixed-mesh gripper for cuMotion. Uses the same mesh    -->
    <!-- file as GraspGen so the collision model and grasp-frame       -->
    <!-- convention are identical; no 90 deg rotation needed here.     -->
    <joint name="${prefix}iiwa_to_grasp_frame" type="fixed">
      <parent link="${prefix}iiwa_link_7"/>
      <child link="${prefix}grasp_frame"/>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}grasp_frame">
      <visual>
        <geometry>
          <mesh filename="package://agile_manip_description/meshes/robotiq_140/robotiq_140_collision.stl"/>
        </geometry>
        <material name="gripper_dark"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://agile_manip_description/meshes/robotiq_140/robotiq_140_collision.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.9"/>
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
        <inertia ixx="0.0015" ixy="0.0" ixz="0.0" iyy="0.0015" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>
  </xacro:unless>

</robot>
